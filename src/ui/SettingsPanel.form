<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ui.SettingsPanel">
  <grid id="27dc6" binding="contentPane" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="125" y="42" width="565" height="278"/>
    </constraints>
    <properties>
      <background color="-16777216"/>
      <enabled value="true"/>
    </properties>
    <border type="none"/>
    <children>
      <grid id="51e77" binding="sidePanelEast" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="East"/>
        <properties>
          <background color="-16777216"/>
        </properties>
        <border type="none"/>
        <children>
          <hspacer id="dd864">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="10" use-parent-layout="false"/>
            </constraints>
          </hspacer>
          <vspacer id="171a7">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
            </constraints>
          </vspacer>
        </children>
      </grid>
      <grid id="134a0" binding="sidePanelWest" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="West"/>
        <properties>
          <background color="-16777216"/>
        </properties>
        <border type="none"/>
        <children>
          <hspacer id="cb0ba">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="10" use-parent-layout="false"/>
            </constraints>
          </hspacer>
          <vspacer id="8f4f5">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
            </constraints>
          </vspacer>
        </children>
      </grid>
      <grid id="67e0e" binding="midlePanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <scrollpane id="a3aa4" binding="scrollPane" custom-create="true">
            <constraints border-constraint="Center"/>
            <properties>
              <background color="-13041920"/>
            </properties>
            <border type="none"/>
            <children/>
          </scrollpane>
          <grid id="e3f8c" binding="buttonsPanel" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
            <constraints border-constraint="South"/>
            <properties>
              <background color="-14869219"/>
            </properties>
            <border type="none"/>
            <children>
              <component id="79d38" class="javax.swing.JButton" binding="buttonBack" custom-create="true">
                <constraints/>
                <properties>
                  <text value="Back"/>
                </properties>
              </component>
              <component id="6e045" class="javax.swing.JButton" binding="buttonReset" custom-create="true">
                <constraints/>
                <properties>
                  <text value="Reset"/>
                </properties>
              </component>
              <component id="bfcde" class="javax.swing.JButton" binding="buttonApply" custom-create="true">
                <constraints/>
                <properties>
                  <text value="Apply"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
    </children>
  </grid>
</form>
